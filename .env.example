# ==========================================================
# Credenciais da SyncPay (pegue em https://web.syncpay.pro/gateway/)
# Copie este arquivo para ".env" e preencha com os seus dados.
# NUNCA suba o arquivo .env para o GitHub.
# ==========================================================

SYNCPAY_CLIENT_ID=cole-seu-client-id-aqui
SYNCPAY_CLIENT_SECRET=cole-seu-client-secret-aqui

# URL base da API (normalmente não precisa mudar)
SYNCPAY_BASE_URL=https://api.syncpayments.com.br

# (Opcional) URL pública que a SyncPay chama quando o PIX é pago (webhook).
# Deve apontar para a rota /webhook deste servidor, ex:
#   https://seudominio.com/webhook
# Deixe em branco em desenvolvimento local (o site usa polling nesse caso).
SYNCPAY_POSTBACK_URL=

# Valor mínimo permitido (em R$)
MIN_AMOUNT=10

# Dados do cliente enviados à SyncPay (mockados)
MOCK_NAME=Cliente Mimos
MOCK_CPF=11144477735
MOCK_EMAIL=mimo@mimos.app
MOCK_PHONE=11999999999

# Porta do servidor local
PORT=3000
